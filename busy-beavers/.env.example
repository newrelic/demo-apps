# Busy Beavers — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================
# License key — used by the NR Python agent on both services
# Get yours at: https://one.newrelic.com/launcher/api-keys-ui.api-keys-launcher
NEW_RELIC_LICENSE_KEY=your_license_key_here

# User API key — used by the frontend to call NerdGraph (change marker button)
# Create one at: https://one.newrelic.com/api-keys (type: User)
NEW_RELIC_API_KEY=your_api_key_here

# Application names as they appear in the NR UI
NEW_RELIC_APP_NAME_FRONTEND=busy-beavers_frontend
NEW_RELIC_APP_NAME_BACKEND=busy-beavers_backend

# ============================================================================
# LOAD GENERATOR TUNING (optional)
# ============================================================================
# Number of concurrent Selenium users
LOADGEN_USERS=2

# Base seconds between each user's transactions (± 1.5s jitter)
# 2 users * (60 / 6s) ≈ 20 transactions/minute
LOADGEN_INTERVAL=6
