# =============================================================================
# ReliFarm — local Docker Compose environment template
#
# THIS FILE IS FOR THE DOCKER COMPOSE PATH ONLY (`docker compose --env-file .env up`).
# For the AWS deploy path, fill in `terraform/terraform.tfvars.example` instead.
#
# Copy to `.env` and fill in real values. NEVER commit `.env` (it's gitignored).
# =============================================================================

# --- New Relic ---------------------------------------------------------------
# REQUIRED for Docker Compose. Without a real value here, the NR Python agent
# inside the core-engine container will fail to register and you'll see no
# telemetry in NR. Format: 40 chars ending in `NRAL`.
NEW_RELIC_LICENSE_KEY=<your_ingest_license_key>

# NOT USED by Docker Compose. These are read by Terraform when provisioning
# the Browser app + Synthetic monitor. They're listed here only so this file
# matches `terraform.tfvars.example` for engineers running both paths.
# Leave the placeholder values in place; they won't break the local stack.
NEW_RELIC_API_KEY=<your_user_api_key>
NEW_RELIC_ACCOUNT_ID=<your_account_id>
NEW_RELIC_REGION=US

# Optional. APM entity name + agent verbosity. Override only if you want a
# unique-per-engineer name to avoid colliding with shared deployments.
NEW_RELIC_APP_NAME=relifarm-core-engine
NEW_RELIC_LOG_LEVEL=info

# --- Postgres (core-engine) --------------------------------------------------
# REQUIRED. These wire the FastAPI service to the Postgres container that
# `docker compose up` brings up alongside it.
POSTGRES_USER=relifarm
POSTGRES_PASSWORD=relifarm_local_pw
POSTGRES_DB=relifarm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Core-engine -------------------------------------------------------------
# Optional. Port the FastAPI service listens on (host and container).
CORE_ENGINE_PORT=8000

# Optional. How often the background sensor/tractor simulator coroutine ticks.
SIMULATION_INTERVAL_SECONDS=5
